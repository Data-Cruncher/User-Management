# ---------------------------------------------------------------------------
# Sybase ASE Unlock Portal — environment configuration
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ---------------------------------------------------------------------------

# --- General ---
APP_NAME=Sybase ASE User Unlock Portal
ENVIRONMENT=development        # development | staging | production
DEBUG=false

# --- Security / Sessions ---
# Generate strong random values, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_long_random_secret
CSRF_SECRET=changeme_generate_a_different_long_random_secret
SESSION_MAX_AGE_MINUTES=30
COOKIE_SECURE=true              # set to true once served over HTTPS
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- LDAP / Active Directory ---
LDAP_ENABLED=false
LDAP_SERVER=ldap://your-ldap-server:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_DN_TEMPLATE=uid={username},ou=people,dc=example,dc=com
LDAP_USE_MOCK=true              # set false once a real LDAP server is configured

# --- RBAC ---
DBA_GROUP_NAME=sybase_dba

# --- Sybase ASE ---
SYBASE_SERVERS=PRODSYB01,PRODSYB02,UATSYB01
SYBASE_DSN_TEMPLATE=DRIVER={{FreeTDS}};SERVER={server};PORT=5000;TDS_Version=5.0;
SYBASE_USERNAME=svc_unlock_portal
SYBASE_PASSWORD=changeme_use_a_least_privilege_service_account
SYBASE_CONNECT_TIMEOUT_SECONDS=5
SYBASE_USE_MOCK=true            # set false once pyodbc + a real ASE DSN are configured

# --- Protected / system logins that can never be unlocked via this tool ---
PROTECTED_LOGINS=sa,sso_role,sybase,probe,replication_user,dbo

# --- Audit database ---
AUDIT_DB_URL=sqlite:///./logs/audit.db

# --- Logging ---
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
